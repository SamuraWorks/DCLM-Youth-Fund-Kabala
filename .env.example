# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Access Control Configuration
# Comma-separated lists of emails for automatic approval and admin access
ADMIN_EMAILS="admin1@example.com, admin2@example.com, admin3@example.com"
COORDINATOR_EMAILS="coordinator@example.com"

# DB Seeding Configuration (Used by scripts/seed-admins.ts)
SEED_ADMIN_NAME_1="Admin One"
SEED_ADMIN_EMAIL_1="admin1@example.com"
SEED_ADMIN_PASSWORD_1="SecurePass1!"

SEED_ADMIN_NAME_2="Admin Two"
SEED_ADMIN_EMAIL_2="admin2@example.com"
SEED_ADMIN_PASSWORD_2="SecurePass2!"

SEED_ADMIN_NAME_3="Admin Three"
SEED_ADMIN_EMAIL_3="admin3@example.com"
SEED_ADMIN_PASSWORD_3="SecurePass3!"
